{
  "name": "SDM630 Modbus → MQTT Bridge",
  "version": "1.0.1",
  "slug": "sdm630_mqtt",
  "description": "Bridge voor Eastron SDM630 via USR-TCP232-410S naar MQTT",
  "arch": ["amd64", "armv7", "armhf", "aarch64"],
  "startup": "services",
  "boot": "auto",
  "options": {
    "usr_ip": "192.168.1.182",
    "usr_port": 502,
    "slave_id": 1,
    "mqtt_broker": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_topic": "home/sdm630"
  },
  "schema": {
    "usr_ip": "str",
    "usr_port": "int",
    "slave_id": "int",
    "mqtt_broker": "str",
    "mqtt_port": "int",
    "mqtt_topic": "str"
  }
}
